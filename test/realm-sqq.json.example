{
  "realm": "sqq",
  "enabled": true,
  "displayName": "Superquinquin (test)",
  "loginTheme": "surdeule",
  "sslRequired": "external",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "test-app",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:8088/*", "http://localhost:3000/*"],
      "webOrigins": ["*"]
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "name": "odoo",
        "providerId": "odoo-user-storage",
        "subComponents": {},
        "config": {
          "odoo-url": ["https://odoo.example.com"],
          "odoo-database": ["odoo_database_name"],
          "admin-login": ["service-account@example.com"],
          "admin-password": ["CHANGE_ME"],
          "store-password": ["false"],
          "encryption-key": [""],
          "enabled": ["true"],
          "priority": ["0"],
          "fullSyncPeriod": ["3600"],
          "changedSyncPeriod": ["-1"],
          "cachePolicy": ["DEFAULT"]
        }
      }
    ]
  }
}